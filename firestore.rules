rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    function isValidUserProfile(data) {
      return data.uid == request.auth.uid 
        && (data.email == null || data.email is string)
        && (data.displayName == null || data.displayName is string)
        && (data.role == null || data.role in ['client', 'expert', 'admin']);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || resource.data.role == 'expert' || isAdmin();
      allow list: if (resource.data.role == 'expert' && resource.data.status == 'active') 
                  || (isSignedIn() && resource.data.uid == request.auth.uid)
                  || isAdmin();
      
      allow create: if isOwner(userId) 
        && incoming().uid == request.auth.uid
        && (incoming().role == 'admin' ? false : true) // Prevent self-admin
        && (incoming().walletBalance == null || incoming().walletBalance == 0)
        && (incoming().role == 'client' ? (incoming().status == null || incoming().status == 'active') : true);

      allow update: if (isOwner(userId) && (
        incoming().role == existing().role || (existing().role == 'client' && incoming().role == 'expert')
      )) || isAdmin();
    }

    // --- Sessions ---
    function isValidSession(data) {
      return data.clientId is string && data.expertId is string
        && data.status in ['pending', 'active', 'completed', 'resolved', 'not-resolved-mutual', 'dispute', 'cancelled']
        && data.basePrice is number
        && data.totalPaid is number;
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (
        resource.data.clientId == request.auth.uid || 
        resource.data.expertId == request.auth.uid || 
        isAdmin()
      );
      
      allow create: if isSignedIn() 
        && isValidSession(incoming())
        && incoming().clientId == request.auth.uid; // Only client can initiate

      allow update: if isSignedIn() && (
        (resource.data.clientId == request.auth.uid || resource.data.expertId == request.auth.uid)
        && isValidSession(incoming())
        && incoming().clientId == existing().clientId
        && incoming().expertId == existing().expertId
      ) || isAdmin();
    }

    // --- Chat Rooms ---
    match /chatRooms/{roomId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      
      allow create: if isSignedIn() 
        && request.auth.uid in incoming().participants
        && incoming().participants.size() == 2;

      allow update: if isSignedIn() 
        && request.auth.uid in existing().participants
        && incoming().participants == existing().participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants || isAdmin());
        allow create: if isSignedIn() 
          && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants
          && incoming().senderId == request.auth.uid
          && incoming().text is string && incoming().text.size() <= 2000;
      }
    }

    // --- Feedback ---
    match /feedback/{feedbackId} {
      allow create: if true; // Public feedback for marketing
      allow read: if isAdmin();
    }
  }
}
