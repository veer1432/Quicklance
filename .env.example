# Quicklance frontend deployment config.
# Copy to .env.local for local development. Add the same keys in Vercel Project Settings.

# Launch mode
VITE_FEEDBACK_MODE=false
VITE_PAYMENT_MODE=test_credits
VITE_ADMIN_EMAIL="admin@example.com"
VITE_JITSI_DOMAIN="meet.jit.si"

# Firebase Web App config
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_APP_ID="your-firebase-web-app-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_MEASUREMENT_ID=""

# Leave empty if using the default Firestore database.
VITE_FIRESTORE_DATABASE_ID=""

# Reserved for future AI features. Not currently used by the app.
VITE_GEMINI_API_KEY=""
