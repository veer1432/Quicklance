{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information for both clients and experts.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "expert", "admin"] },
        "bio": { "type": "string" },
        "hourlyRate": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "active", "blocked", "suspended", "rejected"] },
        "walletBalance": { "type": "number" },
        "totalEarnings": { "type": "number" }
      },
      "required": ["uid", "email", "displayName", "role"]
    },
    "Session": {
      "title": "Session",
      "description": "Represents a video call session between client and expert.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "expertId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "resolved", "not-resolved-mutual", "dispute", "cancelled"] },
        "startTime": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "totalPaid": { "type": "number" }
      },
      "required": ["clientId", "expertId", "status", "startTime"]
    },
    "ChatRoom": {
      "title": "Chat Room",
      "description": "A conversation between a client and an expert.",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "clientId": { "type": "string" },
        "expertId": { "type": "string" },
        "lastMessage": { "type": "string" }
      },
      "required": ["participants", "clientId", "expertId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles by UID."
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Individual sessions."
    },
    "/chatRooms/{roomId}": {
      "schema": "ChatRoom",
      "description": "Chat conversations."
    },
    "/chatRooms/{roomId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a chat room."
    },
    "/feedback/{feedbackId}": {
      "schema": "FeedbackResponse",
      "description": "Market survey feedback responses."
    }
  }
}
